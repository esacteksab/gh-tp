exec gh-tp
exists plan.out
exists plan.md
stdout '✔  Plan Created...'
stdout '✔  Markdown Created...'
cmp plan.md tfgolden.md

-- .tp.toml --
binary = 'terraform'
planFile = 'plan.out'
mdFile = 'plan.md'
useTemplate = true
verbose = false

-- foo.tf --

-- .github/pull_request_template.md --
## ACME-XXXX <!-- Replace with your Jira ticket ID -->

## Description <!-- Describe your changes and any relevant context -->

## References <!-- Add any relevant docs or related PRs -->

-- tfgolden.md --
## ACME-XXXX <!-- Replace with your Jira ticket ID -->

## Description <!-- Describe your changes and any relevant context -->

## References <!-- Add any relevant docs or related PRs -->

<details><summary>Terraform plan</summary>

```terraform

No changes. Your infrastructure matches the configuration.

Terraform has compared your real infrastructure against your configuration
and found no differences, so no changes are needed.

```

</details>
-- formatters --
# This exists because the formatters try and remove more than one line and it breaks golden.md
